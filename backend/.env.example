# ----------------------------------------------------------------------------
# Variables d'environnement du backend AppDePorte
# Copiez ce fichier en `.env` et renseignez vos valeurs.
# ----------------------------------------------------------------------------

# (Obligatoire) Clé API Gemini, créée sur https://aistudio.google.com/apikey
GEMINI_API_KEY=votre_cle_api_ici

# (Optionnel) Modèle d'image Gemini à utiliser.
GEMINI_MODEL=gemini-2.5-flash-image

# (Optionnel) Timeout en secondes pour l'appel à l'API Gemini.
GEMINI_TIMEOUT=120

# (Optionnel) Origines frontend autorisées (CORS), séparées par des virgules.
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
