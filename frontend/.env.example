# Le navigateur appelle le proxy interne de Next (/api), jamais le backend en direct.
# Garder /api permet d'exposer toute l'app via un seul domaine (pas de CORS).
NEXT_PUBLIC_API_URL=/api

# Cible du proxy /api côté serveur Next (voir next.config.mjs).
# En local : http://localhost:8000  |  En prod : l'URL du backend (Railway).
BACKEND_URL=https://appporte-production.up.railway.app
